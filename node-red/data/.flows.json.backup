    {
        "id": "fea47e0786fac282",
        "type": "function",
        "z": "7bd870335f289f7f",
        "name": "Ajouter équipement à Liste",
        "func": "var equipement = flow.get('equipement');\nvar ip = flow.get('IP');\nvar dns = flow.get('DNS');\n\n// Vérification de la durée\nnode.warn('ajout équipement : ' + equipement);\n\nvar equipements = flow.get('equipements') || [];\n\nvar newEquipement = {\n    \"equipement\": equipement,\n    \"ip\": ip,\n    \"DNS\":dns\n};\n\nequipements.push(newEquipement);\nflow.set('equipements', equipements);\n\nmsg.payload = equipements;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 200,
        "wires": [
            [
                "69c056a6603a8807"
            ]
        ]
    },
