    {
        "id": "276fc8d5f2ed883f",
        "type": "function",
        "z": "0bf1db1120823ea7",
        "name": "Tri des IP ( ordre croissant ) ",
        "func": "// Trier par adresse IP (ordre croissant)\nmsg.payload.sort((a, b) => {\n    let ipA = a.ip.split('.').map(num => parseInt(num, 10));\n    let ipB = b.ip.split('.').map(num => parseInt(num, 10));\n\n    for (let i = 0; i < 4; i++) {\n        if (ipA[i] !== ipB[i]) {\n            return ipA[i] - ipB[i];\n        }\n    }\n    return 0;\n});\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1170,
        "y": 140,
        "wires": [
            [
                "e55179947568a067",
                "643bd3613cff5879"
            ]
        ]
    },
