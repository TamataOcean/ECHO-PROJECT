        "command": "sh -c 'ping_ok=0; /usr/bin/ping -c1 -W1 \"$1\" >/dev/null 2>&1 && ping_ok=1; mount_ok=$(df -P /app/EXPORT_VIDEOS 2>/dev/null | grep -c \"$1\"); echo \"${ping_ok}:${mount_ok}\"' -- ",
