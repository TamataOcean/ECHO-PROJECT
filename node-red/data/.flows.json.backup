    {
        "id": "a1b2c3nas0002",
        "type": "ui_template",
        "z": "9437544a0f6eb7b6",
        "group": "a1b2c3nas0001",
        "name": "Statut Stockage",
        "order": 1,
        "width": "12",
        "height": "8",
        "format": "<div style=\"padding:6px 2px\">\n\n  <!-- Statut stockage -->\n  <div ng-if=\"msg\" style=\"display:flex;align-items:center;gap:14px;min-height:46px\">\n    <i class=\"material-icons\" ng-style=\"{color:msg.color,fontSize:'38px'}\">{{msg.icon}}</i>\n    <div style=\"flex:1\">\n      <div style=\"font-weight:600;font-size:1em\" ng-style=\"{color:msg.color}\">{{msg.title}}</div>\n      <div style=\"color:#888;font-size:0.82em;margin-top:3px\">{{msg.subtitle}}</div>\n    </div>\n    <button ng-if=\"!msg.showForm\"\n            ng-click=\"send({topic:'umount_nas'})\"\n            style=\"padding:4px 10px;background:#757575;color:white;border:none;border-radius:4px;cursor:pointer;font-size:0.8em;white-space:nowrap\">\n      Démonter\n    </button>\n  </div>\n  <div ng-if=\"!msg\" style=\"color:#aaa;font-style:italic\">Vérification du stockage en cours...</div>\n\n  <!-- Formulaire configuration NAS -->\n  <div ng-show=\"msg && msg.showForm\"\n       style=\"margin-top:12px;padding-top:10px;border-top:1px solid #e0e0e0\">\n    <div style=\"font-size:0.85em;color:#555;margin-bottom:8px;font-weight:600\">Configuration du partage NAS (CIFS) :</div>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:6px 12px;margin-bottom:10px\">\n      <div>\n        <div style=\"font-size:0.78em;color:#777;margin-bottom:2px\">IP / Hostname</div>\n        <input ng-model=\"nasIpModel\" type=\"text\" placeholder=\"192.168.0.17\"\n               style=\"width:100%;box-sizing:border-box;padding:6px 8px;border:1px solid #ccc;border-radius:4px;font-size:0.88em\">\n      </div>\n      <div>\n        <div style=\"font-size:0.78em;color:#777;margin-bottom:2px\">Nom du partage</div>\n        <input ng-model=\"nasShareModel\" type=\"text\" placeholder=\"ECHO_VIDEOs\"\n               style=\"width:100%;box-sizing:border-box;padding:6px 8px;border:1px solid #ccc;border-radius:4px;font-size:0.88em\">\n      </div>\n      <div>\n        <div style=\"font-size:0.78em;color:#777;margin-bottom:2px\">Utilisateur</div>\n        <input ng-model=\"nasUserModel\" type=\"text\" placeholder=\"raspi\"\n               style=\"width:100%;box-sizing:border-box;padding:6px 8px;border:1px solid #ccc;border-radius:4px;font-size:0.88em\">\n      </div>\n      <div>\n        <div style=\"font-size:0.78em;color:#777;margin-bottom:2px\">Mot de passe</div>\n        <input ng-model=\"nasPassModel\" type=\"password\" placeholder=\"••••••\"\n               style=\"width:100%;box-sizing:border-box;padding:6px 8px;border:1px solid #ccc;border-radius:4px;font-size:0.88em\">\n      </div>\n    </div>\n    <button ng-click=\"send({topic:'save_nas', payload:{host:nasIpModel, share:nasShareModel, user:nasUserModel, pass:nasPassModel}})\"\n            style=\"padding:7px 20px;background:#1976D2;color:white;border:none;border-radius:4px;cursor:pointer;font-size:0.88em\">\n      Sauvegarder et Monter\n    </button>\n  </div>\n\n</div>\n\n<script>\nscope.$watch('msg', function(msg) {\n    if (!msg || !msg.showForm) return;\n    if (!scope.nasIpModel) scope.nasIpModel = msg.nasHost || '';\n    if (!scope.nasShareModel) scope.nasShareModel = msg.nasShare || '';\n    if (!scope.nasUserModel) scope.nasUserModel = msg.nasUser || '';\n});\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1030,
        "y": 940,
        "wires": [
            [
                "a1b2c3nas0007"
            ]
        ]
    },
    {
        "id": "a1b2c3nas0003",
        "type": "inject",
        "z": "9437544a0f6eb7b6",
        "name": "Check NAS (30s)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "30",
        "crontab": "",
        "once": true,
        "onceDelay": 5,
        "topic": "",
        "payload": "",
        "payloadType": "str",
        "x": 170,
        "y": 940,
        "wires": [
            [
                "a1b2c3nas0004"
            ]
        ]
    },
    {
        "id": "a1b2c3nas0004",
        "type": "function",
        "z": "9437544a0f6eb7b6",
        "name": "Prépare ping NAS",
        "func": "var nasHost = global.get('NAS_HOST') || '';\nvar nasShare = global.get('NAS_SHARE') || '';\nvar nasUser = global.get('NAS_USER') || '';\nif (!nasHost) {\n    global.set('VIDEO_PATH', '/data/local_videos/');\n    msg.icon = 'storage';\n    msg.color = '#2196F3';\n    msg.title = 'NAS non configuré';\n    msg.subtitle = 'Aucun NAS renseigné — Vidéos enregistrées en local (/data/local_videos/)';\n    msg.showForm = true;\n    msg.nasHost = nasHost; msg.nasShare = nasShare; msg.nasUser = nasUser;\n    node.send([null, msg]);\n    return null;\n}\nmsg.payload = nasHost;\nmsg.nasHost = nasHost; msg.nasShare = nasShare; msg.nasUser = nasUser;\nreturn msg;",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "x": 440,
        "y": 940,
        "wires": [
            [
                "7323e54970ece752"
            ],
            [
                "a1b2c3nas0002"
            ]
        ]
    },
    {
        "id": "a1b2c3nas0006",
        "type": "function",
        "z": "9437544a0f6eb7b6",
        "name": "Traite résultat NAS",
        "func": "var nasHost = global.get('NAS_HOST') || 'NAS';\nvar nasShare = global.get('NAS_SHARE') || '';\nvar nasUser = global.get('NAS_USER') || '';\nvar parts = (msg.payload || '').toString().trim().split(':');\nvar pingOk = parts[0] === '1';\nvar mounted = parseInt(parts[1] || '0') > 0;\nmsg.nasHost = nasHost; msg.nasShare = nasShare; msg.nasUser = nasUser;\nif (pingOk && mounted) {\n    global.set('VIDEO_PATH', '/app/EXPORT_VIDEOS/');\n    msg.icon = 'cloud_done';\n    msg.color = '#4CAF50';\n    msg.title = 'NAS Connecté et Monté  —  ' + nasHost;\n    msg.subtitle = 'Vidéos enregistrées sur le NAS (/app/EXPORT_VIDEOS/)';\n    msg.showForm = false;\n} else if (pingOk) {\n    global.set('VIDEO_PATH', '/data/local_videos/');\n    msg.icon = 'cloud_queue';\n    msg.color = '#FF9800';\n    msg.title = 'NAS Joignable mais Non Monté  —  ' + nasHost;\n    msg.subtitle = 'Partage réseau non monté — Vidéos enregistrées en local';\n    msg.showForm = true;\n} else {\n    global.set('VIDEO_PATH', '/data/local_videos/');\n    msg.icon = 'cloud_off';\n    msg.color = '#F44336';\n    msg.title = 'NAS Non Disponible  —  ' + nasHost;\n    msg.subtitle = 'NAS injoignable — Vidéos enregistrées en local';\n    msg.showForm = true;\n}\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "x": 820,
        "y": 880,
        "wires": [
            [
                "a1b2c3nas0002"
            ]
        ]
    },
    {
        "id": "a1b2c3nas0007",
        "type": "function",
        "z": "9437544a0f6eb7b6",
        "name": "Sauvegarde IP NAS",
        "func": "if (msg.topic === 'umount_nas') {\n    return [null, msg];\n}\nif (msg.topic !== 'save_nas') return null;\nvar d = msg.payload || {};\nvar host = (d.host || '').trim();\nvar share = (d.share || '').trim();\nvar user = (d.user || '').trim();\nvar pass = (d.pass || '').trim();\nif (!host) return null;\nglobal.set('NAS_HOST', host);\nglobal.set('NAS_SHARE', share);\nglobal.set('NAS_USER', user);\nglobal.set('NAS_PASS', pass);\nmsg.payload = 'NAS_HOST=' + host + ' NAS_SHARE=' + share + ' NAS_USER=' + user + ' NAS_PASS=' + pass;\nreturn [msg, null];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "x": 780,
        "y": 1000,
