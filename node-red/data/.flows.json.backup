    {
        "id": "78e41c42029fa962",
        "type": "function",
        "z": "0bf1db1120823ea7",
        "name": "Delete Doublons",
        "func": "// Récupérer les résultats\nlet results = msg.payload;\n\n// Créer un objet pour stocker le dernier statut de chaque IP\nlet filteredResults = {};\nlet filteredDns = {};\n\nresults.forEach(device => {\n    filteredResults[device.ip] = device.status;  // Remplace la valeur existante\n    filteredDns[device.ip] = device.dns;\n});\n\n// Transformer l'objet en tableau\nmsg.payload = Object.keys(filteredResults).map((ip,dns) => ({\n    ip: ip,\n    dns: filteredDns[ip],\n    status: filteredResults[ip]\n}));\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 910,
        "y": 140,
        "wires": [
            [
                "423c1b32fed266a7",
                "276fc8d5f2ed883f"
            ]
        ]
    },
