# ============================================================
# Echo Project — Variables d'environnement
# ============================================================

# --- Chemins sur l'hôte (Raspberry Pi) ---
LOCAL_VIDEO_PATH=/mnt/NVME/EXPORT_VIDEOS

# --- Configuration MQTT ---
# Ces valeurs sont internes au container (network_mode: host).
# Ne pas modifier sauf si vous changez les topics dans server.py.
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_CONTROL=gstreamer/control
MQTT_TOPIC_LOGS=server/log

# --- Chemin vidéo interne au container ---
EXPORT_VIDEO_ROOT=/app/EXPORT_VIDEOS

# --- NAS (laisser vide si pas de NAS) ---
# Adresse IP ou hostname du NAS utilisé pour vérifier la connectivité
# Exemple : NAS_HOST=192.168.1.200
NAS_HOST=192.168.0.17

# --- Système ---
TIMEZONE=Europe/Paris
PUID=1000
PGID=1000
